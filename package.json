{
	"name": "@dlazy/cli",
	"version": "1.0.7",
	"description": "Command-line interface for dLazy AI workflow, allowing direct invocation of various large models in the terminal",
	"author": "dLazy",
	"license": "MIT",
	"main": "dist/index.js",
	"files": [
		"dist"
	],
	"bin": {
		"dlazy": "./dist/index.js"
	},
	"scripts": {
		"start": "node dist/index.js",
		"build": "tsup src/index.ts --format cjs",
		"prepublishOnly": "pnpm run build",
		"dev": "tsx src/index.ts",
		"pack": "pnpm run build && pnpm pack",
		"test": "pnpm -w exec vitest run packages/cli/tests"
	},
	"dependencies": {
		"commander": "^12.0.0",
		"dotenv": "^16.4.5",
		"mime-types": "^2.1.35",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/mime-types": "^3.0.1",
		"@types/node": "^25.5.2",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
