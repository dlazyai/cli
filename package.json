{
	"name": "@dlazy/cli",
	"version": "1.1.1",
	"description": "Command-line interface for dLazy AI workflow, allowing direct invocation of various large models in the terminal",
	"author": "dLazy",
	"license": "MIT",
	"main": "dist/sdk.js",
	"types": "dist/sdk.d.ts",
	"files": [
		"dist"
	],
	"bin": {
		"dlazy": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/sdk.d.ts",
			"require": "./dist/sdk.js",
			"default": "./dist/sdk.js"
		},
		"./sdk": {
			"types": "./dist/sdk.d.ts",
			"require": "./dist/sdk.js",
			"default": "./dist/sdk.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"start": "node dist/index.js",
		"build": "tsup",
		"prepublishOnly": "pnpm run build",
		"dev": "DLAZY_BASE_URL=http://localhost:3000 tsx src/index.ts",
		"pack": "pnpm run build && pnpm pack",
		"skills:sync": "DLAZY_BASE_URL=http://localhost:3000 npx tsx scripts/sync-skills.ts && npx tsx scripts/sync-agent-skills.ts && npx tsx scripts/sync-extra-skills.ts",
		"skills:extra": "DLAZY_BASE_URL=http://localhost:3000 npx tsx scripts/sync-extra-skills.ts",
		"skills:export": "npx tsx scripts/export-skills.ts",
		"test": "pnpm -w exec vitest run packages/cli/tests --testTimeout=600000",
		"publish:skills": "npx tsx publish-skills.ts",
		"publish:skills:new": "npx tsx publish-skills.ts --new-only",
		"publish:npm": "pnpm publish --no-git-checks",
		"test:integration": "DLAZY_INTEGRATION=1 pnpm -w exec vitest run packages/cli/tests/integration.test.ts --testTimeout=600000"
	},
	"dependencies": {
		"commander": "^12.0.0",
		"mime-types": "^2.1.35"
	},
	"devDependencies": {
		"@types/mime-types": "^3.0.1",
		"@types/node": "^25.5.2",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	}
}
