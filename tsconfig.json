{
	"compilerOptions": {
		"target": "es2022",
		"module": "commonjs",
		"outDir": "./dist",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"],
		"baseUrl": "../..",
		"paths": {
			"@/*": ["./*"]
		}
	},
	"include": ["src/**/*"]
}
